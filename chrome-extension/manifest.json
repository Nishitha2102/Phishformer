{\n  "manifest_version": 3,\n  "name": "Phishformer",\n  "version": "1.0",\n  "description": "An extension for phishing protection.",\n  "permissions": [\n    "storage",\n    "webRequest",\n    "webRequestBlocking",\n    "https://*/*",\n    "http://*/*"\n  ],\n  "background": {\n    "service_worker": "background.js"\n  },\n  "content_scripts": [\n    {\n      "matches": ["<all_urls>"],\n      "js": ["content.js"]\n    }\n  ],\n  "action": {\n    "default_popup": "popup.html",\n    "default_icon": "icon.png"\n  },\n  "icons": {\n    "48": "icon.png"\n  }\n}